# Python bytecode / build artifacts
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/

# Virtual environment (uv-managed)
.venv/

# Tool caches
.mypy_cache/
.pytest_cache/
.ruff_cache/

# Test coverage
.coverage
.coverage.*
coverage.xml
htmlcov/

# IDEs / editors
.idea/
*.swp
# Keep the small, intentional .vscode files committed; ignore everything else.
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# OS junk
.DS_Store
Thumbs.db

# Local env files (may contain secrets)
.env
.env.*
